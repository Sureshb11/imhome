{
  "expo": {
    "name": "imhome-app",
    "slug": "imhome-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imhome-logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/imhome-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/imhome-logo.png",
      "bundler": "metro",
      "output": "single",
      "name": "I'mHome.Care — Smart Care at Home"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
